project_name       = "helium"
environment        = "prod"
aws_region         = "us-east-1"
availability_zones = ["us-east-1a", "us-east-1b"]

# Fargate sizing — 0.5 vCPU / 1 GB for the FastAPI backend (scale up if Open3D
# reconstruction jobs run inside the task rather than as async workers)
task_cpu    = 512
task_memory = 1024

desired_count = 1

# ACM cert ARN for HTTPS — leave empty to start with HTTP only
# certificate_arn = "arn:aws:acm:us-east-1:123456789012:certificate/..."

log_retention_days = 30

# Helium app config
helium_data_dir          = "/tmp/data"
helium_min_images        = 8
helium_max_images        = 20
helium_max_image_size_mb = 20
