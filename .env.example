# ── Storage ──────────────────────────────────────────────────────────────────
# Directory where all job data (audio, artifacts, metadata) is stored.
# Defaults to ~/.helium when unset.
HELIUM_DATA_DIR=./data

# ── Audio constraints ─────────────────────────────────────────────────────────
HELIUM_MIN_AUDIO_FILES=1
HELIUM_MAX_AUDIO_FILES=6
HELIUM_MAX_AUDIO_SIZE_MB=100
HELIUM_TARGET_SPEAKERS=2

# ── Hugging Face access token ─────────────────────────────────────────────────
# Required for diarization.  Steps:
#   1. Create a token at https://hf.co/settings/tokens (read scope is enough)
#   2. Accept model conditions at https://hf.co/pyannote/speaker-diarization-community-1
#   3. Paste your token here (never commit this file with a real token)
HELIUM_HF_TOKEN=hf_your_token_here

# ── Model backends ────────────────────────────────────────────────────────────
# Override to swap implementations; defaults are set in helium/config.py.
# HELIUM_DIARIZATION_BACKEND=pyannote/speaker-diarization-community-1
# HELIUM_SEPARATION_BACKEND=speechbrain/sepformer-whamr
# HELIUM_CONVERSION_BACKEND=RedRepter/seed-vc-api

# ── Server (FastAPI backend only) ─────────────────────────────────────────────
HELIUM_HOST=0.0.0.0
HELIUM_PORT=8000
